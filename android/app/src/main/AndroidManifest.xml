<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══ 网络 ═══════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ══ 来电检测 (危险权限) ═══════════════════════════════════ -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- ══ 短信拦截 (危险权限) ═══════════════════════════════════ -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- ══ 通知 (Android 13+) ═══════════════════════════════════ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ══ 后台服务 ═══════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ══ 语音分析 (用户同意后启用) ══════════════════════════════ -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ══ 硬件特性 ═══════════════════════════════════════════════ -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:name=".CampusSafetyApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CampusSafety"
        android:usesCleartextTraffic="false"
        tools:targetApi="33">

        <!-- ══ 启动 Activity ══════════════════════════════════════ -->
        <activity
            android:name=".ui.activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.CampusSafety.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ══ 登录 Activity ══════════════════════════════════════ -->
        <activity
            android:name=".ui.activity.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ══ 主 Activity (Bottom Nav + 5 Fragments) ════════════ -->
        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize" />

        <!-- ══ 案例详情 Activity ══════════════════════════════════ -->
        <activity
            android:name=".ui.activity.CaseDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- ══ 检测结果 Activity (SSE 流式 CoT 展示) ══════════════ -->
        <activity
            android:name=".ui.activity.DetectionResultActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ══ 举报 Activity ══════════════════════════════════════ -->
        <activity
            android:name=".ui.activity.ReportActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ══ 设置 Activity ══════════════════════════════════════ -->
        <activity
            android:name=".ui.activity.SettingsActivity"
            android:exported="false" />

        <!-- ══ 前台服务：通话监测 ═══════════════════════════════════ -->
        <service
            android:name=".service.CallMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ══ FCM 推送服务 ═══════════════════════════════════════ -->
        <service
            android:name=".service.FcmMessageService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ══ 短信接收器 ═════════════════════════════════════════ -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- ══ 开机启动接收器 ═══════════════════════════════════════ -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- ══ FCM 元数据 ═════════════════════════════════════════ -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/fcm_channel_id" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_shield" />
    </application>
</manifest>
