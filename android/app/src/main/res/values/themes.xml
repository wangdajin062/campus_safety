<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CampusSafety" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/bg_gray</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>
    </style>

    <style name="Theme.CampusSafety.Splash" parent="Theme.CampusSafety">
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@drawable/bg_splash</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/white</item>
        <item name="itemIconTint">@drawable/nav_item_color</item>
        <item name="itemTextColor">@drawable/nav_item_color</item>
        <item name="itemRippleColor">#1A1976D2</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Toolbar -->
    <style name="AppToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <!-- Card -->
    <style name="CardElevated">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Button primary -->
    <style name="BtnPrimary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Chip -->
    <style name="ChipFilter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Text styles -->
    <style name="TextH1">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextH2">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextBody1">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>
    <style name="TextBody2">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>
    <style name="TextCaption">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>
</resources>
