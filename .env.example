# ══════════════════════════════════════════════════════════════
# QAD-MultiGuard v4.1 — 校园安全 APP 环境变量模板
# ══════════════════════════════════════════════════════════════
# Quick setup:
#   cp .env.example .env
#   python3 -c "import secrets; c=open('.env').read(); \
#     c=c.replace('CHANGE_ME_SECRET_KEY', secrets.token_hex(32)); \
#     c=c.replace('CHANGE_ME_DB_PASSWORD', secrets.token_urlsafe(24)); \
#     c=c.replace('CHANGE_ME_REDIS_PASSWORD', secrets.token_urlsafe(16)); \
#     open('.env','w').write(c); print('env ready')"
#
# Required: DB_PASSWORD, SECRET_KEY, REDIS_PASSWORD
# ══════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────
APP_ENV=production
API_VERSION=4.1.0
ALLOWED_ORIGINS=["https://campus-safety.com","https://api.campus-safety.com"]
LOG_LEVEL=info

# ── JWT Secret (required, min 32 chars) ────────────────────
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS_LONG
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=1
JWT_REFRESH_EXPIRE_DAYS=7

# ── PostgreSQL (required) ──────────────────────────────────
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/campus_safety

# ── Redis (required) ──────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
SMS_CODE_EXPIRE_SECONDS=300
RATE_LIMIT_PER_MINUTE=100

# ── SMS Service (optional, dev default prints to log) ─────
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=校园安全
SMS_TEMPLATE_CODE=SMS_000000

# ── Push Notification (FCM, optional) ─────────────────────
FCM_SERVER_KEY=

# ── ML Inference (v4.1 speculative decoding config) ───────
DRAFT_MODEL_PATH=/models/fraud_draft_q4km.gguf
VERIFY_MODEL_URL=http://llm-server:8001
GAMMA=5

# ── GPU Acceleration (optional) ───────────────────────────
# CUDA_VISIBLE_DEVICES=0
# HF_TOKEN=hf_your_token_here
