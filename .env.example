# ══════════════════════════════════════════════════════════════
# 校园安全 APP v3 — 环境变量配置模板
# 复制命令: python3 -c "import secrets; c=open('.env.example').read(); c=c.replace('change_me_256bit_secret_key_here_minimum_32_chars',secrets.token_hex(32)); c=c.replace('change_me_strong_password_here',secrets.token_urlsafe(24)); c=c.replace('change_me_redis_password',secrets.token_urlsafe(16)); open('.env','w').write(c); print('✅ .env ready')"
# ══════════════════════════════════════════════════════════════

# ── 数据库（必填）──────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password_here
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/campus_safety

# ── Redis（必填）───────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── JWT 认证（必填，最少32字符）────────────────────────────────
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_256bit_secret_key_here_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30
SMS_CODE_EXPIRE_SECONDS=300

# ── 短信服务（可选，不填则开发模式，验证码打印在日志中）────────
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your_aliyun_access_key
SMS_SECRET_KEY=your_aliyun_secret_key
SMS_SIGN_NAME=校园安全
SMS_TEMPLATE_CODE=SMS_000000000

# ── Firebase Cloud Messaging（可选，不填则推送不可用）──────────
FCM_SERVER_KEY=your_fcm_server_key_from_firebase_console

# ── 应用配置 ───────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=["https://campus-safety.com","https://api.campus-safety.com"]
RATE_LIMIT_PER_MINUTE=100

# ── ML 推理（可选，不配置则使用统计先验降级模式）───────────────
DRAFT_MODEL_PATH=/models/fraud_draft_q4km.gguf
VERIFY_MODEL_URL=http://llm-server:8001
GAMMA=5
# HF_TOKEN=hf_your_token_here
