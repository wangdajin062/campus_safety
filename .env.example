# ══════════════════════════════════════════════════════════════
# QAD-MultiGuard v4.1 — 校园安全 APP 环境变量模板
# 软硬协同多模态检测 | 推测解码 | 隐私保护
# ══════════════════════════════════════════════════════════════
# 快速部署:
#   cp .env.example .env
#   python3 -c "import secrets; c=open('.env').read(); \
#     c=c.replace('CHANGE_ME_SECRET_KEY', secrets.token_hex(32)); \
#     c=c.replace('CHANGE_ME_DB_PASSWORD', secrets.token_urlsafe(24)); \
#     c=c.replace('CHANGE_ME_REDIS_PASSWORD', secrets.token_urlsafe(16)); \
#     open('.env','w').write(c); print('env ready')"
# ══════════════════════════════════════════════════════════════

# ── 应用配置 ───────────────────────────────────────────────────
APP_ENV=production
APP_NAME="校园安全 v4.1"
API_VERSION=4.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=["https://campus-safety.com","https://api.campus-safety.com"]

# ── JWT 密钥（必填，最少 32 字符）───────────────────────────────
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS_LONG
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=1
JWT_REFRESH_EXPIRE_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/campus_safety

# ── Redis（验证码/限流/黑名单）──────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
SMS_CODE_EXPIRE_SECONDS=300
RATE_LIMIT_PER_MINUTE=100

# ── 短信服务（可选，不填则开发模式验证码打印在日志中）────────────
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your_aliyun_access_key
SMS_SECRET_KEY=your_aliyun_secret_key
SMS_SIGN_NAME=校园安全
SMS_TEMPLATE_CODE=SMS_000000

# ── 推送服务（FCM，可选）───────────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ── ML 推理（v4.1 推测解码配置）─────────────────────────────────
DRAFT_MODEL_PATH=/models/fraud_draft_q4km.gguf
VERIFY_MODEL_URL=http://llm-server:8001
GAMMA=5

# ── 声学嵌入 DP 隐私保护（可选）────────────────────────────────
# DP_SIGMA=0.0         # 0.0=关闭, 1.0=(ε=9.69, δ=1e-5)-DP
# EMBEDDING_DIM=128

# ── GPU 加速（可选）────────────────────────────────────────────
# CUDA_VISIBLE_DEVICES=0
# HF_TOKEN=hf_your_token_here
